{
  "name": "drone-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for creating and operating drones through Drone Hub",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "files": [
    "dist/**",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./hub": "./dist/hub.js",
    "./testing": "./dist/testing.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "bun test tests",
    "test:coverage": "bun test --coverage tests",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
